# ===========================================
# Environment Configuration Example
# ===========================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# --- Exchange Configuration ---
# Supported: binance, bybit, bingx, okx, bitget
EXCHANGE_CCXT=binance

# --- API Credentials (Optional - for higher rate limits) ---
# Leave empty for public read-only access

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=

# BingX
BINGX_API_KEY=
BINGX_API_SECRET=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

# Bitget
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSWORD=
