htmlcov/
.tox/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
nosetests.xml
pytestdebug.log

# --- Jupyter ---
.ipynb_checkpoints

# --- Local Development ---
local_work/

# --- Pre-commit ---
.secrets.baseline
.pre-commit-cache/
coin-volume-list-*.zip
