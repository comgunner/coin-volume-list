__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.manifest
*.spec

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
pyvenv.cfg

# --- IDE / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.log
secrets.py
auth.json
api_key.json

# --- Generated Data ---
output/*.json
!output/.gitkeep

# --- AI Agent Context Files ---
CLAUDE.md
GEMINI.md
QWEN.md
REFACTORING.md
CONTRIBUTING.md
.claude/
.agent/
.qwen/
.gemini/

